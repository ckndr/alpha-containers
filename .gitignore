# ── Excel files — NEVER commit (contain business data) ──
*.xlsx
*.xls
*.xlsm

# Keep the main versioned Tubex workbook synced for home/office work.
!Tubex_v*.xlsx

# ── ERP exports & data files ──
*.pdf

# ── Python cache ──
__pycache__/
*.pyc
*.pyo
*.pyd
.Python

# Local logs
Logs/*.log

# Local tools/apps that should not upload to GitHub
# Aerosol/ is now a project subfolder and tracked
!Aerosol/
!Aerosol/**/*.xlsx
!Aerosol/**/*.pdf
*.exe

# ── Windows junk ──
Thumbs.db
desktop.ini
$RECYCLE.BIN/

# ── OneDrive sync artifacts ──
*.tmp
~$*

# ── Backup copies ──
*_backup*
*_old*
*_copy*

# ── One-off debug/AI artifacts ──
excel_for_ai.json
mrp_dump.txt


# ── Documentation (keep in repo) ──
# MONTH_CHECKLIST.md and PIPELINE.md are tracked intentionally
# (they are NOT in the ignore list)

# ── Pre-run backups (local only) ──
Logs/backup_*
